# 监控配置
MONITOR_INTERVAL=900000  # 15分钟 (毫秒)
PRICE_CHANGE_THRESHOLD=0.1  # 涨跌幅阈值 (%)

# 涨跌通知：回看窗口内最高/最低价（秒），避免分多步下跌漏报；默认 3600=1 小时
PRICE_ALERT_LOOKBACK_SECONDS=3600
# 同一资产两次通知最短间隔（秒），0=不限制
ALERT_COOLDOWN_SECONDS=300

# API 代理（国内服务器如需代理访问外部 API 可配置）
API_PROXY_HOST=
API_PROXY_PORT=

# 邮件通知配置
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_TO=recipient@example.com

# Webhook通知配置
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://your-webhook-url.com
WEBHOOK_TYPE=dingtalk  # dingtalk, wecom, custom

# Telegram通知配置
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Web 服务端口
PORT=3001

# 数据库
DATABASE_PATH=./data/crypto.db

# JWT 密钥（必须修改为随机字符串）
JWT_SECRET=change-me-to-a-random-string

# Stripe 订阅支付（可选，不配置则不显示升级按钮）
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
SITE_URL=http://localhost:3001
